Description: Override navigator.hardwareConcurrency to return a spoofed
 consumer value instead of the server's real CPU count. The switch
 kAbpFingerprintHardwareConcurrency and reader GetHardwareConcurrency()
 already exist but no Blink-side patch applies them.

--- a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
+++ b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
@@ -5,10 +5,19 @@
 #include "third_party/blink/renderer/core/frame/navigator_concurrent_hardware.h"

 #include "base/system/sys_info.h"
+#include "base/command_line.h"
+#include "chrome/browser/abp/stealth/abp_stealth_utils.h"

 namespace blink {

 unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  // ABP stealth: return spoofed value to hide server CPU count.
+  if (abp::stealth::IsStealthEnabled()) {
+    int spoofed = abp::stealth::GetHardwareConcurrency();
+    if (spoofed > 0)
+      return static_cast<unsigned>(spoofed);
+  }
+
   unsigned int logical_processors = base::SysInfo::NumberOfProcessors();
   return logical_processors > 0 ? logical_processors : 1;
 }
