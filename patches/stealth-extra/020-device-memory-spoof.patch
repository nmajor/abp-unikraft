Description: Override navigator.deviceMemory to return a realistic consumer
 value instead of the server's real RAM. Servers with 64GB+ memory are
 an obvious non-consumer signal for fingerprinters.

--- a/third_party/blink/renderer/core/frame/navigator_device_memory.cc
+++ b/third_party/blink/renderer/core/frame/navigator_device_memory.cc
@@ -5,6 +5,8 @@
 #include "third_party/blink/renderer/core/frame/navigator_device_memory.h"

 #include "base/system/sys_info.h"
+#include "base/command_line.h"
+#include "chrome/browser/abp/stealth/abp_stealth_utils.h"

 namespace blink {

@@ -15,6 +17,13 @@ float NavigatorDeviceMemory::deviceMemory() const {
   // Return the approximate amount of device memory, bucketed and
   // clamped to powers of 2 in range [0.25, 8].
   // https://w3c.github.io/device-memory/#sec-device-memory-js-api
+
+  // ABP stealth: return a realistic consumer value (8 GB).
+  // This avoids leaking server memory (e.g., 64 GB) which is a
+  // strong signal for server-side browser detection.
+  if (abp::stealth::IsStealthEnabled()) {
+    return 8.0f;
+  }
+
   return ApproximatedDeviceMemory::GetApproximatedDeviceMemory();
 }
